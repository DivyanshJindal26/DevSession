# Firebase service account key — paste the entire JSON on one line
# Get this from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_CREDS_JSON={"type":"service_account","project_id":"..."}

# MongoDB Atlas connection string
# Get this from Atlas: Connect > Drivers > copy the URI, replace <password>
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/devnotes?retryWrites=true&w=majority

# Firebase web config (Project Settings > General > Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
